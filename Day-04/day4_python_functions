48. Common Mistake

Forgetting return.

'''

def add(a,b):

    a+b


x = add(10,20)

print(x)

# None



'''
49. Common Mistake

Mutable Default Arguments

Avoid:

'''

def bad(nums=[]):

    nums.append(1)

    return nums


'''
Preferred:

'''

def good(nums=None):

    if nums is None:

        nums = []



